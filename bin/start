#!/usr/bin/env bash
# start — Start a devbox VM and SSH into it.
#
# Usage: ./bin/start --profile <name>
#
# Adds a "devbox-<profile>" entry to ~/.ssh/config on first run.
# Updates HostName with the current ephemeral IP on subsequent runs.

set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$BIN_DIR/../devbox/lib/profile"

PROFILE=$(parse_profile_flag "$@")
load_profile "$PROFILE"
check_gcp_project
check_gcloud_auth
resolve_instance_zone

SSH_KEY="$HOME/.ssh/zaeem_devbox"
SSH_USER="zaeem"
SSH_CONFIG="$HOME/.ssh/config"
SSH_HOST="devbox-${PROFILE_NAME}"

# ---------------------------------------------------------------------------
# SSH agent check
# ---------------------------------------------------------------------------
if ! ssh-add -l &>/dev/null; then
  log_warn "SSH agent has no keys loaded"
  log_dim "If this is a fresh VM, the repo clone will fail without agent forwarding."
  log_dim "Fix: ssh-add ~/.ssh/zaeem_devbox"
  echo
fi

# ---------------------------------------------------------------------------
# VM: start + wait for SSH + wait for startup script
# ---------------------------------------------------------------------------
log_section "VM ($GCP_INSTANCE_NAME)"

log_info "Starting $GCP_INSTANCE_NAME..."
gcloud compute instances start "$GCP_INSTANCE_NAME" \
  --zone="$GCP_ZONE" --project="$GCP_PROJECT" --quiet
log_ok "Instance started"

_poll_ssh() {
  local instance="$1" zone="$2" project="$3" user="$4" key="$5" out="$6"
  for i in $(seq 1 30); do
    local ip
    ip=$(gcloud compute instances describe "$instance" \
      --zone="$zone" --project="$project" \
      --format="get(networkInterfaces[0].accessConfigs[0].natIP)" 2>/dev/null || true)
    if [[ -n "$ip" ]] && ssh \
         -o StrictHostKeyChecking=no -o ConnectTimeout=30 \
         -i "$key" -o BatchMode=yes "${user}@${ip}" true 2>/dev/null; then
      echo "$ip" > "$out"
      return 0
    fi
    sleep 5
  done
  return 1
}

_diagnose_ssh_failure() {
  local instance="$1" zone="$2" project="$3" user="$4" key="$5"

  log_section "SSH Diagnostics"

  local status
  status=$(gcloud compute instances describe "$instance" \
    --zone="$zone" --project="$project" \
    --format="value(status)" 2>/dev/null || echo "unknown")
  if [[ "$status" == "RUNNING" ]]; then
    log_ok "VM status: RUNNING"
    log_dim "sshd not ready, wrong key, or firewall block"
  else
    log_warn "VM status: $status — expected RUNNING"
  fi

  local ip
  ip=$(gcloud compute instances describe "$instance" \
    --zone="$zone" --project="$project" \
    --format="get(networkInterfaces[0].accessConfigs[0].natIP)" 2>/dev/null || true)
  if [[ -z "$ip" ]]; then
    log_warn "No external IP — the VM has no natIP; check accessConfig in Terraform"
    return
  fi
  log_ok "External IP: $ip"

  log_warn "SSH connection attempt (verbose output):"
  echo
  ssh -vvv -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
    -o BatchMode=yes -i "$key" "${user}@${ip}" true 2>&1 \
    | grep -E "(Connecting to|connect to address|Permission denied|Connection refused|Connection timed out|Received disconnect|Host key|debug1: Authentications)" \
    | head -15 \
    | while IFS= read -r line; do log_dim "$line"; done
  echo

  log_warn "Serial console — last 20 lines:"
  echo
  gcloud compute instances get-serial-port-output "$instance" \
    --zone="$zone" --project="$project" 2>/dev/null \
    | tail -20 \
    | while IFS= read -r line; do log_dim "$line"; done
  echo
}

IP_FILE=$(mktemp)
trap 'rm -f "$IP_FILE"' EXIT

log_info "Waiting for SSH (up to 2.5 min)..."
if ! _poll_ssh "$GCP_INSTANCE_NAME" "$GCP_ZONE" "$GCP_PROJECT" "$SSH_USER" "$SSH_KEY" "$IP_FILE"; then
  log_error "Could not reach VM over SSH after 30 attempts"
  _diagnose_ssh_failure "$GCP_INSTANCE_NAME" "$GCP_ZONE" "$GCP_PROJECT" "$SSH_USER" "$SSH_KEY"
  exit 1
fi
IP=$(cat "$IP_FILE")
log_ok "VM is up at $IP"

_poll_startup() {
  local user="$1" ip="$2" key="$3"
  for i in $(seq 1 30); do
    if ssh -o StrictHostKeyChecking=no -o ConnectTimeout=30 \
         -i "$key" -o BatchMode=yes "${user}@${ip}" \
         "sudo test -f /var/lib/startup-complete" 2>/dev/null; then
      return 0
    fi
    sleep 5
  done
  return 1
}

log_info "Waiting for startup script to complete (up to 2.5 min)..."
if ! _poll_startup "$SSH_USER" "$IP" "$SSH_KEY"; then
  log_warn "Startup script did not complete within expected time — connecting anyway"
else
  log_ok "Startup script complete"
fi

ssh-keygen -R "$IP" &>/dev/null || true

# ---------------------------------------------------------------------------
# Setup: secrets, terminfo
# ---------------------------------------------------------------------------
log_section "Setup"

LOCAL_SECRETS="$REPO_ROOT/devbox/profiles/${PROFILE_NAME}.env"
if [[ -f "$LOCAL_SECRETS" ]]; then
  log_info "Copying secrets (${PROFILE_NAME}.env)..."
  if ssh -o StrictHostKeyChecking=no -o ConnectTimeout=30 -i "$SSH_KEY" \
       "${SSH_USER}@${IP}" 'mkdir -p ~/.config && chmod 700 ~/.config' \
     && scp -o StrictHostKeyChecking=no -i "$SSH_KEY" \
       "$LOCAL_SECRETS" "${SSH_USER}@${IP}:.config/secrets.env" \
     && ssh -o StrictHostKeyChecking=no -o ConnectTimeout=30 -i "$SSH_KEY" \
       "${SSH_USER}@${IP}" 'chmod 600 ~/.config/secrets.env'; then
    log_ok "Secrets copied to ~/.config/secrets.env"
  else
    log_warn "Failed to copy secrets — you can retry by re-running bin/start"
  fi
else
  log_warn "No secrets file at ${LOCAL_SECRETS} — skipping"
fi

log_info "Installing Ghostty terminfo..."
if infocmp -x | ssh -o StrictHostKeyChecking=no -o ConnectTimeout=30 \
     -i "$SSH_KEY" "${SSH_USER}@${IP}" -- tic -x - 2>/dev/null; then
  log_ok "Ghostty terminfo installed"
else
  log_warn "Could not install Ghostty terminfo (non-fatal, will retry on next start)"
fi

# ---------------------------------------------------------------------------
# SSH config: add or update devbox-<profile> entry
# ---------------------------------------------------------------------------
log_section "SSH config"

touch "$SSH_CONFIG"
chmod 600 "$SSH_CONFIG"

if grep -q "^Host ${SSH_HOST}$" "$SSH_CONFIG" 2>/dev/null; then
  python3 - "$SSH_CONFIG" "$IP" "$SSH_HOST" "$SSH_KEY" <<'PYEOF'
import sys, re
config_file, new_ip, host, new_key = sys.argv[1], sys.argv[2], sys.argv[3], sys.argv[4]
with open(config_file) as f:
    content = f.read()
# Update HostName
content = re.sub(
    r'(Host ' + re.escape(host) + r'\n(?:[ \t]+\S.*\n)*?[ \t]+HostName )\S+',
    lambda m: m.group(1) + new_ip,
    content
)
# Update IdentityFile (keeps key path current across renames)
content = re.sub(
    r'(Host ' + re.escape(host) + r'\n(?:[ \t]+\S.*\n)*?[ \t]+IdentityFile )\S+',
    lambda m: m.group(1) + new_key,
    content
)
with open(config_file, 'w') as f:
    f.write(content)
PYEOF
  log_ok "Updated $SSH_HOST → $IP"
else
  cat >> "$SSH_CONFIG" <<EOF

Host ${SSH_HOST}
  HostName $IP
  User $SSH_USER
  IdentityFile $SSH_KEY
  StrictHostKeyChecking no
  ForwardAgent yes
  ConnectTimeout 30
EOF
  log_ok "Added $SSH_HOST to SSH config"
fi

echo
log_info "Connecting to $SSH_HOST..."
echo
ssh -A "$SSH_HOST"
