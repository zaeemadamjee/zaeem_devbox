#!/usr/bin/env bash
# rigging — Set up dev environment on a fresh macOS machine (Apple Silicon).
#
# Usage: ./bin/rigging [command]
#
# Commands:
#   all      Run install + link + shell + langs + tools  (default)
#   install  Run brew bundle from pkgs/Brewfile
#   link     Stow config packages into ~ (dotfiles)
#   shell    Write ~/.config/zaeem/shell.zsh and source it from ~/.zshrc
#   langs    Install language toolchains (sourced from pkgs/lang/*)
#   tools    Install coding tools (claude code, opencode, TPM)
#   check    Print status of all components without modifying anything
#   help     Show this message
#
# Safe to re-run (idempotent).

set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$BIN_DIR/.." && pwd)"
CONFIG_DIR="$REPO_ROOT/config"
BREW_PREFIX="/opt/homebrew"

# ---------------------------------------------------------------------------
# Phase 1 — plain-echo bootstrap (runs before lib/log.sh is available)
# ---------------------------------------------------------------------------

_pre_ok()   { printf "  \033[32m✓\033[0m  %s\n" "$*"; }
_pre_info() { printf "  %s\n" "$*"; }

# Xcode CLI tools are required for Homebrew and git.
if ! xcode-select -p &>/dev/null; then
  _pre_info "Xcode CLI tools not found — triggering install dialog..."
  xcode-select --install
  _pre_info "Waiting for Xcode CLI tools to finish installing..."
  until xcode-select -p &>/dev/null; do sleep 5; done
  _pre_ok "Xcode CLI tools"
fi

# Homebrew
if ! command -v brew &>/dev/null; then
  _pre_info "Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$("${BREW_PREFIX}/bin/brew" shellenv)"
  _pre_ok "Homebrew"
else
  eval "$(brew shellenv 2>/dev/null || true)"
fi

export BREW_PREFIX

# lib/log.sh is now sourceable — switch to it for all remaining output.
# shellcheck source=../lib/log.sh
source "$REPO_ROOT/lib/log.sh"
# shellcheck source=../lib/banner.sh
source "$REPO_ROOT/lib/banner.sh"

# ---------------------------------------------------------------------------
# Shared state
# ---------------------------------------------------------------------------
FAILED=()
_track_failed() { FAILED+=("$1"); }

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

_tap_from_file() {
  local file="$1"
  [[ -f "$file" ]] || return 0
  while IFS= read -r tap || [[ -n "$tap" ]]; do
    [[ -z "$tap" || "$tap" =~ ^# ]] && continue
    log_dim "Tapping $tap..."
    brew tap "$tap" </dev/null || log_warn "Failed to tap $tap"
  done <"$file"
}

_install_from_file() {
  local file="$1" flag="${2:-}"
  [[ -f "$file" ]] || { log_error "File not found: $file"; return 1; }
  while IFS= read -r pkg || [[ -n "$pkg" ]]; do
    [[ -z "$pkg" || "$pkg" =~ ^# ]] && continue
    log_dim "Installing $pkg..."
    # shellcheck disable=SC2086
    brew install $flag "$pkg" </dev/null \
      || { log_warn "Failed to install $pkg"; _track_failed "brew $pkg"; }
  done <"$file"
}

cmd_install() {
  log_section "Homebrew packages"
  _tap_from_file     "$REPO_ROOT/pkgs/brew/taps"
  _install_from_file "$REPO_ROOT/pkgs/brew/essentials"
  _install_from_file "$REPO_ROOT/pkgs/brew/casks" --cask
  export PATH="${BREW_PREFIX}/bin:$PATH"
}

cmd_link() {
  log_section "Dotfiles"

  # zsh excluded — rigging manages shell init via cmd_shell, not by stowing
  # the Linux devbox .zshrc.
  local packages="aliases atuin claude git ghostty nvim opencode starship tmux"
  local stow="${BREW_PREFIX}/bin/stow"

  for pkg in $packages; do
    # Dry-run to find conflicts — stow reports exactly which targets block it.
    local conflicts
    conflicts=$(
      "$stow" -d "$CONFIG_DIR" "$pkg" -t "$HOME" --restow -n 2>&1 \
      | grep "existing target is not owned by stow:" \
      | sed 's/.*existing target is not owned by stow: //'
    ) || true

    for conflict in $conflicts; do
      local ctarget="$HOME/$conflict"
      if [[ -L "$ctarget" ]]; then
        rm -f "$ctarget"                                        # stale symlink — remove
      elif [[ -f "$ctarget" || -d "$ctarget" ]]; then
        log_info "Backing up ~/$conflict → ~/${conflict}.bak"
        mv "$ctarget" "${ctarget}.bak"                          # plain file/dir — back up
      fi
    done

    "$stow" -d "$CONFIG_DIR" "$pkg" -t "$HOME" --restow \
      && log_ok "$pkg" \
      || { log_warn "stow $pkg failed"; _track_failed "stow $pkg"; }
  done
}

cmd_shell() {
  log_section "Shell"

  local managed_dir="$HOME/.config/zaeem"
  local managed_file="$managed_dir/shell.zsh"
  local zshrc="$HOME/.zshrc"

  mkdir -p "$managed_dir"

  # Always overwritten so re-runs pick up any new tool init lines.
  cat > "$managed_file" <<'SHELL_INIT'
# macOS shell environment — managed by rigging.
# Re-generated on each run of: rigging shell
# Do not edit directly; changes will be overwritten.

# --- Homebrew (Apple Silicon) ---
export BREW_PREFIX="/opt/homebrew"
eval "$("${BREW_PREFIX}/bin/brew" shellenv)"

# --- PATH ---
export PATH="${BREW_PREFIX}/opt/rustup/bin:$PATH"  # rustup (keg-only)
export PATH="$HOME/.local/bin:$PATH"               # claude code
export PATH="$HOME/.npm-global/bin:$PATH"          # npm globals
export PATH="$HOME/.cargo/bin:$PATH"               # rust/cargo
export PATH="$PATH:$HOME/go/bin"                   # go binaries

# --- nvm ---
export NVM_DIR="$HOME/.nvm"
[[ -s "${BREW_PREFIX}/opt/nvm/nvm.sh" ]]                    && source "${BREW_PREFIX}/opt/nvm/nvm.sh"
[[ -s "${BREW_PREFIX}/opt/nvm/etc/bash_completion.d/nvm" ]] && source "${BREW_PREFIX}/opt/nvm/etc/bash_completion.d/nvm"

# --- Aliases ---
[[ -f "$HOME/.aliases.sh" ]] && source "$HOME/.aliases.sh"

# --- Rust/cargo ---
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# --- fzf ---
[[ -f "$HOME/.fzf.zsh" ]] && source "$HOME/.fzf.zsh"

# --- Starship prompt ---
eval "$(starship init zsh)"

# --- zoxide (smart cd) ---
eval "$(zoxide init zsh)"

# --- atuin (shell history) ---
command -v atuin &>/dev/null && eval "$(atuin init zsh)"

# --- Google Cloud SDK ---
[[ -f "${BREW_PREFIX}/share/google-cloud-sdk/path.zsh.inc" ]]       && source "${BREW_PREFIX}/share/google-cloud-sdk/path.zsh.inc"
[[ -f "${BREW_PREFIX}/share/google-cloud-sdk/completion.zsh.inc" ]] && source "${BREW_PREFIX}/share/google-cloud-sdk/completion.zsh.inc"

# --- Secrets ---
if [[ -f "$HOME/.config/secrets.env" ]]; then
  set -a
  source "$HOME/.config/secrets.env"
  set +a
fi
SHELL_INIT

  log_ok "~/.config/zaeem/shell.zsh"

  # Add managed block to ~/.zshrc exactly once (guarded by sentinel comment).
  touch "$zshrc"
  if grep -qF "# --- zaeem — [added by rigging] ---" "$zshrc" 2>/dev/null; then
    log_info "~/.zshrc: zaeem block already present"
  else
    cat >> "$zshrc" <<EOF

# --- zaeem — [added by rigging] ---
source "${managed_file}"
alias devbox='bash \$HOME/workspace/zaeem/devbox/bin/orchestrator'
alias rigging='bash \$HOME/workspace/zaeem/bin/rigging'
EOF
    log_ok "~/.zshrc updated"
  fi
}

cmd_langs() {
  log_section "Languages"

  # rustup is keg-only — add its bin dir to PATH before the rust lang file runs.
  local brew_rustup="${BREW_PREFIX}/opt/rustup/bin"
  [[ -d "$brew_rustup" ]] && export PATH="$brew_rustup:$PATH"

  for script in "$REPO_ROOT/pkgs/lang"/*; do
    [[ -f "$script" ]] || continue
    local name
    name="$(basename "$script")"
    log_info "$name..."
    # shellcheck source=/dev/null
    source "$script" || { log_warn "$name failed"; _track_failed "lang/$name"; }
  done
}

cmd_tools() {
  log_section "Tools"

  # tmux plugin manager
  if [[ -d "$HOME/.tmux/plugins/tpm" ]]; then
    log_info "tmux plugin manager: already installed"
  else
    log_info "tmux plugin manager: installing..."
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm" \
      && log_ok "tmux plugin manager" \
      || { log_warn "tmux plugin manager failed"; _track_failed "tpm"; }
  fi

  # claude code is installed via cask "claude-code" in pkgs/Brewfile

  # claude plugins
  if [[ ! -d "$HOME/.claude/plugins/superpowers" ]]; then
    log_info "claude superpowers plugin: installing..."
    claude plugin install superpowers@claude-plugins-official \
      && log_ok "superpowers plugin" \
      || { log_warn "superpowers plugin failed"; _track_failed "superpowers plugin"; }
  else
    log_info "claude superpowers plugin: already installed"
  fi

  if [[ ! -d "$HOME/.claude/plugins/impeccable" ]]; then
    log_info "claude impeccable plugin: installing..."
    claude plugin install impeccable@impeccable \
      && log_ok "impeccable plugin" \
      || { log_warn "impeccable plugin failed"; _track_failed "impeccable plugin"; }
  else
    log_info "claude impeccable plugin: already installed"
  fi

  # opencode is installed via brew "anomalyco/tap/opencode" in pkgs/Brewfile

  log_info "Seeding tealdeer page cache..."
  tldr --update >/dev/null 2>&1 || true

  log_info "Importing atuin history..."
  atuin import auto 2>/dev/null || true
}

cmd_check() {
  log_banner "rigging check"

  local missing=()

  _chk() {
    local label="$1" result="$2"
    if [[ "$result" == "ok" ]]; then
      log_ok "$label"
    else
      log_error "$label"
      missing+=("$label")
    fi
  }

  log_section "Prerequisites"
  xcode-select -p &>/dev/null \
    && _chk "Xcode CLI tools" ok || _chk "Xcode CLI tools" fail
  command -v brew &>/dev/null \
    && _chk "Homebrew" ok || _chk "Homebrew" fail

  log_section "Homebrew packages"
  command -v brew &>/dev/null \
    && _chk "brew" ok || _chk "brew" fail

  log_section "Dotfiles"
  local stow="${BREW_PREFIX}/bin/stow"
  for pkg in aliases atuin claude git ghostty nvim opencode starship tmux; do
    "$stow" -d "$CONFIG_DIR" -n "$pkg" -t "$HOME" &>/dev/null \
      && _chk "stow $pkg" ok || _chk "stow $pkg (already linked)" ok
  done

  log_section "Shell"
  local managed_file="$HOME/.config/zaeem/shell.zsh"
  [[ -f "$managed_file" ]] \
    && _chk "~/.config/zaeem/shell.zsh" ok || _chk "~/.config/zaeem/shell.zsh" fail
  grep -qF "source \"${managed_file}\"" "$HOME/.zshrc" 2>/dev/null \
    && _chk "~/.zshrc source line" ok || _chk "~/.zshrc source line" fail

  log_section "Languages"
  command -v rustc   &>/dev/null && _chk "rust"   ok || _chk "rust"   fail
  command -v node    &>/dev/null && _chk "node"   ok || _chk "node"   fail
  command -v go      &>/dev/null && _chk "go"     ok || _chk "go"     fail
  command -v python3 &>/dev/null && _chk "python" ok || _chk "python" fail

  log_section "Tools"
  [[ -d "$HOME/.tmux/plugins/tpm" ]] && _chk "tpm"      ok || _chk "tpm"      fail
  command -v claude   &>/dev/null    && _chk "claude"   ok || _chk "claude"   fail
  command -v opencode &>/dev/null    && _chk "opencode" ok || _chk "opencode" fail
  command -v gcloud   &>/dev/null    && _chk "gcloud"   ok || _chk "gcloud"   fail

  echo
  if [[ ${#missing[@]} -eq 0 ]]; then
    log_ok "All components installed"
  else
    log_error "${#missing[@]} component(s) missing — run: ./bin/rigging"
    exit 1
  fi
}

cmd_all() {
  print_banner "rigging"
  _setup_ssh
  cmd_install
  cmd_link
  cmd_shell
  cmd_langs
  cmd_tools
  _summary
}

cmd_help() {
  print_banner "rigging"
  cat <<EOF

  rigging — provision a fresh macOS machine (Apple Silicon)

  Usage: ./bin/rigging [command]

  Commands:
    all      Run install + link + shell + langs + tools  (default)
    install  Run brew bundle from pkgs/Brewfile
    link     Stow config packages into ~ (dotfiles)
    shell    Write ~/.config/zaeem/shell.zsh and source it from ~/.zshrc
    langs    Install language toolchains (pkgs/lang/*)
    tools    Install coding tools (claude, opencode, TPM)
    check    Print status of all components without modifying anything
    help     Show this message

EOF
}

_setup_ssh() {
  log_section "SSH keys"

  local ssh_dir="$HOME/.ssh"
  local vault_dir="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Documents/Vault"
  local config_file="$ssh_dir/config"

  mkdir -p "$ssh_dir"

  if [[ -f "$ssh_dir/id_ed25519" ]]; then
    log_info "SSH keys already exist"
  else
    if [[ -f "$vault_dir/id_ed25519" ]]; then
      cp "$vault_dir/id_ed25519"     "$ssh_dir/id_ed25519"
      cp "$vault_dir/id_ed25519.pub" "$ssh_dir/id_ed25519.pub"
      chmod 600 "$ssh_dir/id_ed25519"
      chmod 644 "$ssh_dir/id_ed25519.pub"
      log_ok "SSH keys copied from iCloud vault"
    else
      log_info "iCloud vault not found — skipping SSH key setup"
      log_dim "Expected: $vault_dir"
      return 0
    fi
  fi

  if ! grep -q "UseKeychain yes" "$config_file" 2>/dev/null; then
    cat >> "$config_file" <<EOF

Host *
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/id_ed25519
EOF
    chmod 600 "$config_file"
    log_info "SSH config updated (Apple Keychain)"
  fi

  ssh-add --apple-use-keychain "$ssh_dir/id_ed25519" 2>/dev/null || true
}

_summary() {
  echo
  if [[ ${#FAILED[@]} -eq 0 ]]; then
    log_ok "Setup complete — open a new shell for changes to take effect"
  else
    log_warn "Setup complete with ${#FAILED[@]} failure(s):"
    for f in "${FAILED[@]}"; do
      log_dim "  · $f"
    done
    log_dim "Re-run ./bin/rigging to retry."
  fi
  echo
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    all)     cmd_all ;;
    install) log_banner "rigging install"; cmd_install; _summary ;;
    link)    log_banner "rigging link";    cmd_link;    _summary ;;
    shell)   log_banner "rigging shell";   cmd_shell;   _summary ;;
    langs)   log_banner "rigging langs";   cmd_langs;   _summary ;;
    tools)   log_banner "rigging tools";   cmd_tools;   _summary ;;
    check)   cmd_check ;;
    help|--help|-h) cmd_help ;;
    *)
      log_error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
