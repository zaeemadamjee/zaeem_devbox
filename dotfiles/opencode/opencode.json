{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-scheduler", "./pushover-notify.js", "superpowers@git+https://github.com/obra/superpowers.git"],
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "permission": {
    "*": "allow",
    "doom_loop": "allow",
    "external_directory": {
      "**": "allow"
    },
    "read": {
      "*": "allow"
    }
  },
  "server": {
    "hostname": "0.0.0.0",
    "port": 4096,
    "mdns": true
  }
}
