{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["@devtheops/opencode-plugin-otel", "opencode-scheduler"],
  "mcp": {
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp"
    }
  },
  "permission": {
    "*": "allow",
    "doom_loop": "allow",
    "external_directory": {
      "**": "allow"
    },
    "read": {
      "*": "allow"
    }
  }
}
