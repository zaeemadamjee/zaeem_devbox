#!/usr/bin/env bash
# welcome — shown on every interactive SSH login.
# Sourced from ~/.zshrc (outside tmux only).
# WELCOME_SHOWN=1 is exported to prevent re-display if .zshrc is re-sourced.

export WELCOME_SHOWN=1

REPO="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")/../.." && pwd)"

# shellcheck source=../../lib/log.sh
source "$REPO/lib/log.sh"

PROFILE="${DEVBOX_PROFILE:-$(head -1 "$HOME/.config/devbox/profile" 2>/dev/null | tr -d '\r\n' || echo '?')}"

BOOTSTRAPPED=false
[[ -f "$HOME/.rigging-complete" ]] && BOOTSTRAPPED=true

# ---------------------------------------------------------------------------
# System info via neofetch
# ---------------------------------------------------------------------------
if command -v neofetch &>/dev/null; then
  neofetch
else
  log_warn "neofetch not installed — run: rigging install"
fi

# ---------------------------------------------------------------------------
# Bootstrap status
# ---------------------------------------------------------------------------
log_section "devbox"
log_info "Profile:    $PROFILE"

if $BOOTSTRAPPED; then
  log_ok "Rigging: complete"
else
  log_warn "Rigging: not run"
fi

echo

# ---------------------------------------------------------------------------
# If not bootstrapped — offer to run it now
# ---------------------------------------------------------------------------
if ! $BOOTSTRAPPED; then
  printf "  Run rigging now? [Y/n]: "
  read -r _answer
  if [[ "$_answer" != "n" && "$_answer" != "N" ]]; then
    echo
    if bash "$REPO/devbox/bin/rigging"; then
      touch "$HOME/.rigging-complete"
      echo
      # Refresh PATH to pick up Homebrew (just installed by rigging),
      # then go straight into tmux so the tmux shell fully sources .zshrc.
      _brew_prefix="/home/linuxbrew/.linuxbrew"
      [[ -f "${_brew_prefix}/bin/brew" ]] && eval "$("${_brew_prefix}/bin/brew" shellenv)"
      exec tmux new-session -A -s main
    fi
  else
    log_dim "Run any time:      rigging"
    log_dim "Check status only: rigging check"
    echo
  fi
else
  # Already bootstrapped — show a quick health check
  bash "$REPO/devbox/bin/rigging" check || true
  echo
fi

# ---------------------------------------------------------------------------
# Attach to tmux
# ---------------------------------------------------------------------------
if [[ -z "$TMUX" ]] && [[ -t 0 ]]; then
  # Homebrew is not yet in PATH here (it's initialized later in .zshrc).
  # Init it now so we find the Homebrew tmux rather than a stale system one.
  _brew_prefix="/home/linuxbrew/.linuxbrew"
  [[ -f "${_brew_prefix}/bin/brew" ]] && eval "$("${_brew_prefix}/bin/brew" shellenv)" 2>/dev/null || true

  _tmux_bin=$(command -v tmux 2>/dev/null || true)
  if [[ -n "$_tmux_bin" ]]; then
    log_dim "Attaching tmux ($_tmux_bin $(tmux -V 2>/dev/null | cut -d' ' -f2))..."
    exec tmux new-session -A -s main
  else
    log_warn "tmux not found — dropping to shell (run: rigging install)"
  fi
fi
