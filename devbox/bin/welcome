#!/usr/bin/env bash
# welcome — shown on every interactive SSH login.
# Sourced from ~/.zshrc (outside tmux only).
# WELCOME_SHOWN=1 is exported to prevent re-display after exec zsh.

export WELCOME_SHOWN=1

REPO="$HOME/zaeem_devbox"

# shellcheck source=../../lib/log.sh
source "$REPO/lib/log.sh"

PROFILE="${DEVBOX_PROFILE:-$(head -1 "$HOME/.config/devbox/profile" 2>/dev/null | tr -d '\r\n' || echo '?')}"
BOOTSTRAPPED=false
[[ -f "$HOME/.bootstrap-complete" ]] && BOOTSTRAPPED=true

# ---------------------------------------------------------------------------
# System info via neofetch
# ---------------------------------------------------------------------------
if command -v neofetch &>/dev/null; then
  neofetch
else
  log_warn "neofetch not installed — run: bootstrap install"
fi

# ---------------------------------------------------------------------------
# Bootstrap status
# ---------------------------------------------------------------------------
log_section "devbox"
log_info "Profile:    $PROFILE"

if $BOOTSTRAPPED; then
  log_ok "Bootstrap: complete"
else
  log_warn "Bootstrap: not run"
fi

echo

# ---------------------------------------------------------------------------
# If not bootstrapped — offer to run it now
# ---------------------------------------------------------------------------
if ! $BOOTSTRAPPED; then
  printf "  Run bootstrap now? [Y/n]: "
  read -r _answer
  if [[ "$_answer" != "n" && "$_answer" != "N" ]]; then
    echo
    if bash "$REPO/devbox/bin/bootstrap"; then
      touch "$HOME/.bootstrap-complete"
      echo
      exec zsh
    fi
  else
    log_dim "Run any time:      bootstrap"
    log_dim "Check status only: bootstrap check"
    echo
  fi
else
  # Already bootstrapped — show a quick health check
  bash "$REPO/devbox/bin/bootstrap" check || true
  echo
fi

# ---------------------------------------------------------------------------
# Attach to tmux
# ---------------------------------------------------------------------------
if [[ -z "$TMUX" ]] && [[ -t 0 ]] && command -v tmux &>/dev/null; then
  exec tmux new-session -A -s main
fi
