#!/usr/bin/env bash
# bootstrap — Set up a Terraform-provisioned Ubuntu 24.04 devbox VM.
#
# Usage: bootstrap [command]
#
# Commands:
#   all      Run everything  (default)
#   install  Homebrew + brew bundle
#   link     Stow dotfiles + .hushlogin
#   langs    Language toolchains via pkgs/lang/*
#   tools    Claude code, opencode, TPM, atuin, tldr
#   docker   Docker Engine + daemon + group membership
#   idle     Systemd idle timer
#   repos    Clone workspace repos from GCE metadata
#   check    Print ✓/✗ status without modifying anything
#   help     Show this message
#
# Safe to re-run (idempotent).
# Profile is read from DEVBOX_PROFILE env var or ~/.config/devbox/profile.

set -euo pipefail

DEVBOX_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$DEVBOX_BIN_DIR/../.." && pwd)"
CONFIG_DIR="$REPO_ROOT/config"
DEVBOX_DIR="$REPO_ROOT/devbox"
export DEVBOX_BIN_DIR REPO_ROOT CONFIG_DIR DEVBOX_DIR

# shellcheck source=../../lib/log.sh
source "$REPO_ROOT/lib/log.sh"

# ---------------------------------------------------------------------------
# Profile resolution
# ---------------------------------------------------------------------------
_resolve_profile() {
  DEVBOX_PROFILE="${DEVBOX_PROFILE:-}"
  if [[ -z "$DEVBOX_PROFILE" ]] && [[ -f "$HOME/.config/devbox/profile" ]]; then
    DEVBOX_PROFILE="$(head -1 "$HOME/.config/devbox/profile" | tr -d '\r\n')"
  fi
  DEVBOX_PROFILE="${DEVBOX_PROFILE#"${DEVBOX_PROFILE%%[![:space:]]*}"}"
  DEVBOX_PROFILE="${DEVBOX_PROFILE%"${DEVBOX_PROFILE##*[![:space:]]}"}"

  if [[ -z "${DEVBOX_PROFILE// }" ]]; then
    log_error "DEVBOX_PROFILE is not set"
    log_dim "Export DEVBOX_PROFILE=<name> or write one line to ~/.config/devbox/profile"
    exit 1
  fi
  case "$DEVBOX_PROFILE" in
    */*|*..*|\ *) log_error "Invalid DEVBOX_PROFILE '${DEVBOX_PROFILE}'"; exit 1 ;;
  esac

  PROFILE_SCRIPT="$REPO_ROOT/devbox/profiles/${DEVBOX_PROFILE}"
  if [[ ! -f "$PROFILE_SCRIPT" ]]; then
    log_error "Profile script not found: ${PROFILE_SCRIPT}"
    exit 1
  fi

  IDLE_TIMER_ENABLED=true
  # shellcheck source=/dev/null
  source "$PROFILE_SCRIPT"
  log_ok "Profile: ${DEVBOX_PROFILE}"
}

_idle_timer_enabled() {
  case "${IDLE_TIMER_ENABLED:-true}" in
    false|False|FALSE|0|no|No|off|Off) return 1 ;;
    *) return 0 ;;
  esac
}

# ---------------------------------------------------------------------------
# Shared state
# ---------------------------------------------------------------------------
FAILED=()
_track_failed() { FAILED+=("$1"); }

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_install() {
  log_section "Homebrew"

  export BREW_PREFIX="/home/linuxbrew/.linuxbrew"

  if [[ ! -x "${BREW_PREFIX}/bin/brew" ]]; then
    log_info "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
      || { log_error "Homebrew install failed"; _track_failed "homebrew"; return; }
    log_ok "Homebrew"
  else
    log_info "Homebrew already installed"
  fi

  # shellcheck source=/dev/null
  [[ -f "${BREW_PREFIX}/bin/brew" ]] && eval "$("${BREW_PREFIX}/bin/brew" shellenv)"
  export PATH="${BREW_PREFIX}/bin:$PATH"

  if brew bundle check --file="$REPO_ROOT/pkgs/Brewfile" &>/dev/null; then
    log_info "All packages already installed"
  else
    log_info "Running brew bundle (first run may take several minutes)..."
    if ! brew bundle install --file="$REPO_ROOT/pkgs/Brewfile"; then
      log_warn "brew bundle had failures — retrying once (common on first install)..."
      if ! brew bundle install --file="$REPO_ROOT/pkgs/Brewfile"; then
        log_error "brew bundle failed after retry"
        _track_failed "brew bundle"
        return
      fi
    fi
    log_ok "brew bundle"
  fi
}

cmd_link() {
  log_section "Dotfiles"

  if [[ ! -f "$HOME/.hushlogin" ]]; then
    touch "$HOME/.hushlogin"
    log_ok ".hushlogin (suppress Ubuntu MOTD)"
  else
    log_info ".hushlogin already present"
  fi

  local packages="aliases atuin claude git ghostty nvim opencode starship tmux zsh"
  local stow="${BREW_PREFIX}/bin/stow"

  for pkg in $packages; do
    if "$stow" -d "$CONFIG_DIR" -n "$pkg" -t "$HOME" 2>/dev/null; then
      log_info "Linking $pkg..."
      "$stow" -d "$CONFIG_DIR" "$pkg" -t "$HOME" --restow \
        || { log_warn "stow $pkg failed"; _track_failed "stow $pkg"; }
    else
      log_info "$pkg: already linked"
    fi
  done

  log_ok "Dotfiles linked"
}

cmd_langs() {
  log_section "Languages"

  # rustup is keg-only — add its bin dir to PATH before the rust lang file runs.
  local brew_rustup="${BREW_PREFIX}/opt/rustup/bin"
  [[ -d "$brew_rustup" ]] && export PATH="$brew_rustup:$PATH"

  for script in "$REPO_ROOT/pkgs/lang"/*; do
    [[ -f "$script" ]] || continue
    local name
    name="$(basename "$script")"
    log_info "$name..."
    # shellcheck source=/dev/null
    source "$script" || { log_warn "$name failed"; _track_failed "lang/$name"; }
  done
}

cmd_tools() {
  log_section "Tools"

  # tmux plugin manager
  if [[ -d "$HOME/.tmux/plugins/tpm" ]]; then
    log_info "tmux plugin manager: already installed"
  else
    log_info "tmux plugin manager: installing..."
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm" \
      && log_ok "tmux plugin manager" \
      || { log_warn "tpm install failed"; _track_failed "tpm"; }
  fi

  # claude code
  if command -v claude &>/dev/null; then
    log_info "claude code: already installed"
  else
    log_info "claude code: installing (may take a minute)..."
    curl -fsSL https://claude.ai/install.sh | bash \
      && log_ok "claude code" \
      || { log_warn "claude code install failed"; _track_failed "claude code"; }
  fi

  if [[ ! -d "$HOME/.claude/plugins/superpowers" ]]; then
    log_info "claude superpowers plugin: installing..."
    claude plugin install superpowers@claude-plugins-official \
      && log_ok "superpowers plugin" \
      || { log_warn "superpowers plugin failed"; _track_failed "superpowers plugin"; }
  else
    log_info "claude superpowers plugin: already installed"
  fi

  if [[ ! -d "$HOME/.claude/plugins/impeccable" ]]; then
    log_info "claude impeccable plugin: installing..."
    claude plugin install impeccable@impeccable \
      && log_ok "impeccable plugin" \
      || { log_warn "impeccable plugin failed"; _track_failed "impeccable plugin"; }
  else
    log_info "claude impeccable plugin: already installed"
  fi

  # opencode
  if command -v opencode &>/dev/null; then
    log_info "opencode: already installed"
  else
    log_info "opencode: installing (may take a minute)..."
    curl -fsSL https://opencode.ai/install | bash \
      && log_ok "opencode" \
      || { log_warn "opencode install failed"; _track_failed "opencode"; }
  fi

  log_info "Seeding tealdeer page cache..."
  tldr --update >/dev/null 2>&1 || true

  log_info "Importing atuin history..."
  atuin import auto 2>/dev/null || true

  log_ok "Tools"
}

cmd_docker() {
  log_section "Docker"

  if command -v docker &>/dev/null; then
    log_info "Docker Engine: already installed"
  else
    log_info "Docker Engine: installing..."
    curl -fsSL https://get.docker.com | sh \
      && log_ok "Docker Engine" \
      || { log_warn "Docker install failed"; _track_failed "docker"; return; }
  fi

  if systemctl is-active docker &>/dev/null; then
    log_info "Docker daemon: already running"
  else
    log_info "Docker daemon: enabling..."
    sudo systemctl enable --now docker \
      && log_ok "Docker daemon running" \
      || { log_warn "Docker daemon failed to start"; _track_failed "docker daemon"; }
  fi

  if getent group docker | grep -qw "$USER" 2>/dev/null; then
    log_info "docker group: already a member"
  else
    log_info "docker group: adding $USER..."
    sudo usermod -aG docker "$USER" \
      && log_ok "docker group membership" \
      || { log_warn "docker group failed"; _track_failed "docker group"; }
    log_warn "docker group: run 'newgrp docker' or re-login for the change to take effect"
  fi
}

cmd_idle() {
  log_section "Idle timer"

  if _idle_timer_enabled; then
    if systemctl is-enabled devbox-idle.timer &>/dev/null; then
      log_info "devbox-idle timer: already enabled"
    else
      log_info "devbox-idle timer: installing..."
      sudo cp "$DEVBOX_DIR/bin/idle-check" /usr/local/bin/idle-check
      sudo chmod +x /usr/local/bin/idle-check
      sudo cp "$DEVBOX_DIR/idle/devbox-idle.service" /etc/systemd/system/devbox-idle.service
      sudo cp "$DEVBOX_DIR/idle/devbox-idle.timer"   /etc/systemd/system/devbox-idle.timer
      sudo systemctl daemon-reload
      sudo systemctl enable --now devbox-idle.timer \
        && log_ok "devbox-idle timer enabled" \
        || { log_warn "devbox-idle timer failed"; _track_failed "idle timer"; }
    fi
  else
    if systemctl is-enabled devbox-idle.timer &>/dev/null; then
      log_info "Removing idle timer (disabled in profile)..."
      sudo systemctl stop devbox-idle.timer 2>/dev/null || true
      sudo systemctl disable devbox-idle.timer 2>/dev/null || true
      sudo rm -f /etc/systemd/system/devbox-idle.timer \
                 /etc/systemd/system/devbox-idle.service \
                 /usr/local/bin/idle-check
      sudo systemctl daemon-reload
      sudo systemctl reset-failed 2>/dev/null || true
      log_ok "idle timer removed"
    else
      log_info "idle timer: disabled in profile"
    fi
  fi
}

cmd_repos() {
  log_section "Workspace repos"

  local repos_raw
  repos_raw=$(curl -sf \
    --connect-timeout 5 \
    -H "Metadata-Flavor: Google" \
    "http://metadata.google.internal/computeMetadata/v1/instance/attributes/devbox-repos" \
    2>/dev/null || true)

  if [[ -z "$repos_raw" ]]; then
    log_info "No repos configured in profile"
    return
  fi

  if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
    log_warn "SSH agent not forwarded — private repo clones may fail (reconnect with ssh -A)"
  fi

  mkdir -p "$HOME/workspace"

  while IFS= read -r repo_url; do
    [[ -z "$repo_url" ]] && continue
    local repo_name repo_dest
    repo_name=$(basename "$repo_url" .git)
    repo_dest="$HOME/workspace/$repo_name"
    if [[ -d "$repo_dest" ]]; then
      log_info "$repo_name: already cloned"
    else
      log_info "$repo_name: cloning..."
      git clone "$repo_url" "$repo_dest" \
        && log_ok "$repo_name" \
        || { log_warn "$repo_name clone failed"; _track_failed "repo/$repo_name"; }
    fi
  done <<< "$repos_raw"
}

cmd_check() {
  log_banner "bootstrap check"

  local missing=()

  _chk() {
    local label="$1" result="$2"
    if [[ "$result" == "ok" ]]; then
      log_ok "$label"
    else
      log_error "$label"
      missing+=("$label")
    fi
  }

  log_section "Homebrew"
  [[ -x "${BREW_PREFIX}/bin/brew" ]] \
    && _chk "Homebrew" ok || _chk "Homebrew" fail
  brew bundle check --file="$REPO_ROOT/pkgs/Brewfile" &>/dev/null \
    && _chk "brew bundle" ok || _chk "brew bundle" fail

  log_section "Dotfiles"
  [[ -f "$HOME/.hushlogin" ]] \
    && _chk ".hushlogin" ok || _chk ".hushlogin" fail
  local stow="${BREW_PREFIX}/bin/stow"
  for pkg in aliases atuin claude git ghostty nvim opencode starship tmux zsh; do
    "$stow" -d "$CONFIG_DIR" -n "$pkg" -t "$HOME" &>/dev/null \
      && _chk "stow $pkg" ok || _chk "stow $pkg (already linked)" ok
  done

  log_section "Languages"
  command -v rustc   &>/dev/null && _chk "rust"   ok || _chk "rust"   fail
  command -v node    &>/dev/null && _chk "node"   ok || _chk "node"   fail
  command -v go      &>/dev/null && _chk "go"     ok || _chk "go"     fail
  command -v python3 &>/dev/null && _chk "python" ok || _chk "python" fail

  log_section "Tools"
  [[ -d "$HOME/.tmux/plugins/tpm" ]]  && _chk "tpm"      ok || _chk "tpm"      fail
  command -v claude   &>/dev/null      && _chk "claude"   ok || _chk "claude"   fail
  command -v opencode &>/dev/null      && _chk "opencode" ok || _chk "opencode" fail

  log_section "Docker"
  command -v docker &>/dev/null                          && _chk "docker installed" ok || _chk "docker installed" fail
  systemctl is-active docker &>/dev/null                 && _chk "docker running"   ok || _chk "docker running"   fail
  getent group docker | grep -qw "$USER" 2>/dev/null     && _chk "docker group"     ok || _chk "docker group"     fail

  log_section "Idle timer"
  if _idle_timer_enabled; then
    systemctl is-enabled devbox-idle.timer &>/dev/null \
      && _chk "devbox-idle timer" ok || _chk "devbox-idle timer" fail
  else
    log_info "idle timer disabled in profile"
  fi

  log_section "Secrets"
  [[ -s "$HOME/.config/secrets.env" ]] \
    && _chk "~/.config/secrets.env" ok || _chk "~/.config/secrets.env" fail

  echo
  if [[ ${#missing[@]} -eq 0 ]]; then
    log_ok "All components installed"
  else
    log_error "${#missing[@]} component(s) missing — run: bootstrap"
    exit 1
  fi
}

cmd_all() {
  log_banner "bootstrap"
  _resolve_profile
  cmd_install
  cmd_link
  cmd_langs
  cmd_tools
  cmd_docker
  cmd_idle
  cmd_repos
  _secrets_check
  _summary
}

cmd_help() {
  cat <<EOF

  bootstrap — provision a fresh devbox VM

  Usage: bootstrap [command]

  Commands:
    all      Run everything  (default)
    install  Homebrew + brew bundle
    link     Stow dotfiles + .hushlogin
    langs    Language toolchains via pkgs/lang/*
    tools    Claude code, opencode, TPM, atuin, tldr
    docker   Docker Engine + daemon + group membership
    idle     Systemd idle timer
    repos    Clone workspace repos from GCE metadata
    check    Print status without modifying anything
    help     Show this message

EOF
}

_secrets_check() {
  log_section "Secrets"
  if [[ -s "$HOME/.config/secrets.env" ]]; then
    local vars
    mapfile -t vars < <(grep -oP '^(export\s+)?\K[A-Z_][A-Z0-9_]+(?==)' \
      "$HOME/.config/secrets.env" 2>/dev/null || true)
    log_ok "~/.config/secrets.env (${#vars[@]} vars)"
    for v in "${vars[@]}"; do log_dim "  · $v"; done
  else
    log_warn "~/.config/secrets.env not found — run bin/start to copy your profile .env file"
  fi
}

_summary() {
  echo
  if [[ ${#FAILED[@]} -eq 0 ]]; then
    log_ok "Bootstrap complete — log out and back in for shell changes to take effect"
  else
    log_warn "Bootstrap complete with ${#FAILED[@]} failure(s):"
    for f in "${FAILED[@]}"; do log_dim "  · $f"; done
    log_dim "Re-run bootstrap to retry."
  fi
  echo
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-all}"
  shift || true

  # Subcommands that need the profile resolved first
  case "$cmd" in
    all|install|link|langs|tools|docker|idle|repos)
      _resolve_profile
      ;;
  esac

  case "$cmd" in
    all)     cmd_all ;;
    install) log_banner "bootstrap install"; cmd_install; _summary ;;
    link)    log_banner "bootstrap link";    cmd_link;    _summary ;;
    langs)   log_banner "bootstrap langs";   cmd_langs;   _summary ;;
    tools)   log_banner "bootstrap tools";   cmd_tools;   _summary ;;
    docker)  log_banner "bootstrap docker";  cmd_docker;  _summary ;;
    idle)    log_banner "bootstrap idle";    cmd_idle;    _summary ;;
    repos)   log_banner "bootstrap repos";   cmd_repos;   _summary ;;
    check)   _resolve_profile; cmd_check ;;
    help|--help|-h) cmd_help ;;
    *)
      log_error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
