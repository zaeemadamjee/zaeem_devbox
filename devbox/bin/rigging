#!/usr/bin/env bash
# rigging — Set up a Terraform-provisioned Ubuntu 24.04 devbox VM.
#
# Usage: rigging [command]
#
# Commands:
#   all          Run everything  (default)
#   install      Homebrew + brew bundle
#   link         Stow dotfiles + .hushlogin
#   langs        Language toolchains via pkgs/lang/*
#   tools        Claude code, opencode, TPM, atuin, tldr
#   docker       Docker Engine + daemon + group membership
#   tailscale    Install Tailscale daemon + authenticate
#   idle         Systemd idle timer
#   repos        Clone workspace repos from GCE metadata
#   gui          Install GUI stack (XFCE4, RustDesk, Chrome, Ghostty)
#   gui start    Start the GUI session (Xorg + XFCE4 + RustDesk)
#   gui stop     Stop the GUI session
#   check        Print ✓/✗ status without modifying anything
#   help         Show this message
#
# Safe to re-run (idempotent).
# Profile is read from DEVBOX_PROFILE env var or ~/.config/devbox/profile.

set -euo pipefail

DEVBOX_BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$DEVBOX_BIN_DIR/../.." && pwd)"
CONFIG_DIR="$REPO_ROOT/config"
DEVBOX_DIR="$REPO_ROOT/devbox"
BREW_PREFIX="/home/linuxbrew/.linuxbrew"
export DEVBOX_BIN_DIR REPO_ROOT CONFIG_DIR DEVBOX_DIR BREW_PREFIX

# shellcheck source=../../lib/log.sh
source "$REPO_ROOT/lib/log.sh"
# shellcheck source=../../lib/brew.sh
source "$REPO_ROOT/lib/brew.sh"

# ---------------------------------------------------------------------------
# Profile resolution
# ---------------------------------------------------------------------------
_resolve_profile() {
  DEVBOX_PROFILE="${DEVBOX_PROFILE:-}"
  if [[ -z "$DEVBOX_PROFILE" ]] && [[ -f "$HOME/.config/devbox/profile" ]]; then
    DEVBOX_PROFILE="$(head -1 "$HOME/.config/devbox/profile" | tr -d '\r\n')"
  fi
  DEVBOX_PROFILE="${DEVBOX_PROFILE#"${DEVBOX_PROFILE%%[![:space:]]*}"}"
  DEVBOX_PROFILE="${DEVBOX_PROFILE%"${DEVBOX_PROFILE##*[![:space:]]}"}"

  if [[ -z "${DEVBOX_PROFILE// }" ]]; then
    log_error "DEVBOX_PROFILE is not set"
    log_dim "Export DEVBOX_PROFILE=<name> or write one line to ~/.config/devbox/profile"
    exit 1
  fi
  case "$DEVBOX_PROFILE" in
    */*|*..*|\ *) log_error "Invalid DEVBOX_PROFILE '${DEVBOX_PROFILE}'"; exit 1 ;;
  esac

  PROFILE_SCRIPT="$REPO_ROOT/devbox/profiles/${DEVBOX_PROFILE}"
  if [[ ! -f "$PROFILE_SCRIPT" ]]; then
    log_error "Profile script not found: ${PROFILE_SCRIPT}"
    exit 1
  fi

  IDLE_TIMER_ENABLED=true
  # shellcheck source=/dev/null
  source "$PROFILE_SCRIPT"
  log_ok "Profile: ${DEVBOX_PROFILE}"
}

_idle_timer_enabled() {
  case "${IDLE_TIMER_ENABLED:-true}" in
    false|False|FALSE|0|no|No|off|Off) return 1 ;;
    *) return 0 ;;
  esac
}

# ---------------------------------------------------------------------------
# Shared state
# ---------------------------------------------------------------------------
FAILED=()
_track_failed() { FAILED+=("$1"); }

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_install() {
  log_section "Homebrew"

  if [[ ! -x "${BREW_PREFIX}/bin/brew" ]]; then
    log_info "Installing Homebrew (this takes a minute)..."
    local _brew_log
    _brew_log="$(mktemp)"
    if NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)" \
        >"$_brew_log" 2>&1; then
      log_ok "Homebrew"
    else
      log_error "Homebrew install failed — see log: $_brew_log"
      cat "$_brew_log" >&2
      _track_failed "homebrew"
      return
    fi
    rm -f "$_brew_log"
  else
    log_info "Homebrew already installed"
  fi

  # shellcheck source=/dev/null
  [[ -f "${BREW_PREFIX}/bin/brew" ]] && eval "$("${BREW_PREFIX}/bin/brew" shellenv)"
  export PATH="${BREW_PREFIX}/bin:$PATH"

  # Google Cloud CLI — install via apt (the official method on Debian/Ubuntu).
  # Linuxbrew has no cask support so gcloud-cli cask is macOS only.
  if command -v gcloud &>/dev/null; then
    log_info "gcloud already installed"
  else
    log_info "Installing gcloud CLI via apt..."
    curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
      | sudo gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg
    echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
      | sudo tee /etc/apt/sources.list.d/google-cloud-sdk.list > /dev/null
    sudo apt-get update -qq
    sudo apt-get install -y google-cloud-cli \
      && log_ok "gcloud CLI" \
      || { log_warn "gcloud install failed"; _track_failed "gcloud"; }
  fi

  _tap_from_file     "$REPO_ROOT/pkgs/brew/taps"
  _install_from_file "$REPO_ROOT/pkgs/brew/essentials"
  # no casks on Linux — Linuxbrew does not support brew install --cask
}

cmd_link() {
  log_section "Dotfiles"

  if [[ ! -f "$HOME/.hushlogin" ]]; then
    touch "$HOME/.hushlogin"
    log_ok ".hushlogin (suppress Ubuntu MOTD)"
  else
    log_info ".hushlogin already present"
  fi

  local packages="aliases atuin claude git ghostty nvim opencode starship tmux zsh"
  local stow="${BREW_PREFIX}/bin/stow"

  # Remove plain files that would block stow (e.g. the Terraform .zshrc stub,
  # or lines appended by tool installers). Stow can only replace its own symlinks.
  for pkg in $packages; do
    while IFS= read -r src_file; do
      local rel_path="${src_file#"$CONFIG_DIR/$pkg/"}"
      local target="$HOME/$rel_path"
      [[ -f "$target" ]] && [[ ! -L "$target" ]] || continue
      # Skip if the file resolves into our config dir — it's already managed
      # via a stow directory symlink and is not a pre-bootstrap stub.
      local _real
      _real="$(realpath "$target" 2>/dev/null || true)"
      [[ "$_real" == "$CONFIG_DIR"* ]] && continue
      rm -f "$target"
    done < <(find "$CONFIG_DIR/$pkg" -mindepth 1 -maxdepth 3 -type f 2>/dev/null)
  done

  for pkg in $packages; do
    "$stow" -d "$CONFIG_DIR" "$pkg" -t "$HOME" --restow \
      && log_ok "$pkg" \
      || { log_warn "stow $pkg failed"; _track_failed "stow $pkg"; }
  done
}

cmd_langs() {
  log_section "Languages"

  # rustup is keg-only — add its bin dir to PATH before the rust lang file runs.
  local brew_rustup="${BREW_PREFIX}/opt/rustup/bin"
  [[ -d "$brew_rustup" ]] && export PATH="$brew_rustup:$PATH"

  for script in "$REPO_ROOT/pkgs/lang"/*; do
    [[ -f "$script" ]] || continue
    local name
    name="$(basename "$script")"
    log_info "$name..."
    # shellcheck source=/dev/null
    source "$script" || { log_warn "$name failed"; _track_failed "lang/$name"; }
  done
}

cmd_tools() {
  log_section "Tools"

  # tmux plugin manager
  if [[ -d "$HOME/.tmux/plugins/tpm" ]]; then
    log_info "tmux plugin manager: already installed"
  else
    log_info "tmux plugin manager: installing..."
    git clone https://github.com/tmux-plugins/tpm "$HOME/.tmux/plugins/tpm" \
      && log_ok "tmux plugin manager" \
      || { log_warn "tpm install failed"; _track_failed "tpm"; }
  fi

  # claude code
  if command -v claude &>/dev/null; then
    log_info "claude code: already installed"
  else
    log_info "claude code: installing (may take a minute)..."
    curl -fsSL https://claude.ai/install.sh | bash \
      && log_ok "claude code" \
      || { log_warn "claude code install failed"; _track_failed "claude code"; }
  fi

  # opencode — no Linux brew bottle, install via native script
  if command -v opencode &>/dev/null; then
    log_info "opencode: already installed"
  else
    log_info "opencode: installing..."
    curl -fsSL https://opencode.ai/install | bash \
      && log_ok "opencode" \
      || { log_warn "opencode install failed"; _track_failed "opencode"; }
  fi

  log_info "Seeding tealdeer page cache..."
  tldr --update >/dev/null 2>&1 || true

  log_info "Importing atuin history..."
  atuin import auto 2>/dev/null || true

  log_ok "Tools"
}

cmd_docker() {
  log_section "Docker"

  if command -v docker &>/dev/null; then
    log_info "Docker Engine: already installed"
  else
    log_info "Docker Engine: installing (this takes a minute)..."
    local _docker_log
    _docker_log="$(mktemp)"
    if curl -fsSL https://get.docker.com | sh >"$_docker_log" 2>&1; then
      log_ok "Docker Engine"
    else
      log_warn "Docker install failed — see log: $_docker_log"
      cat "$_docker_log" >&2
      _track_failed "docker"
      return
    fi
    rm -f "$_docker_log"
  fi

  if systemctl is-active docker &>/dev/null; then
    log_info "Docker daemon: already running"
  else
    log_info "Docker daemon: enabling..."
    sudo systemctl enable --now docker \
      && log_ok "Docker daemon running" \
      || { log_warn "Docker daemon failed to start"; _track_failed "docker daemon"; }
  fi

  if getent group docker | grep -qw "$USER" 2>/dev/null; then
    log_info "docker group: already a member"
  else
    log_info "docker group: adding $USER..."
    sudo usermod -aG docker "$USER" \
      && log_ok "docker group membership" \
      || { log_warn "docker group failed"; _track_failed "docker group"; }
    log_warn "docker group: run 'newgrp docker' or re-login for the change to take effect"
  fi
}

cmd_tailscale() {
  log_section "Tailscale"

  if command -v tailscale &>/dev/null; then
    log_info "Tailscale: already installed"
  else
    log_info "Tailscale: installing..."
    local _ts_log
    _ts_log="$(mktemp)"
    if curl -fsSL https://tailscale.com/install.sh | sh >"$_ts_log" 2>&1; then
      log_ok "Tailscale installed"
    else
      log_warn "Tailscale install failed — see log: $_ts_log"
      cat "$_ts_log" >&2
      _track_failed "tailscale install"
      return
    fi
    rm -f "$_ts_log"
  fi

  if systemctl is-active tailscaled &>/dev/null; then
    log_info "tailscaled: already running"
  else
    log_info "tailscaled: enabling..."
    sudo systemctl enable --now tailscaled \
      && log_ok "tailscaled running" \
      || { log_warn "tailscaled failed to start"; _track_failed "tailscaled daemon"; return; }
  fi

  if [[ -n "${TAILSCALE_AUTH_KEY:-}" ]]; then
    log_info "Tailscale: authenticating..."
    sudo tailscale up --authkey "$TAILSCALE_AUTH_KEY" --accept-routes \
      && log_ok "Tailscale authenticated" \
      || { log_warn "Tailscale auth failed"; _track_failed "tailscale auth"; }
  else
    log_warn "TAILSCALE_AUTH_KEY not set — skipping auth. Run 'sudo tailscale up' manually."
  fi
}

cmd_idle() {
  log_section "Idle timer"

  if _idle_timer_enabled; then
    if systemctl is-enabled devbox-idle.timer &>/dev/null; then
      log_info "devbox-idle timer: already enabled"
    else
      log_info "devbox-idle timer: installing..."
      sudo cp "$DEVBOX_DIR/bin/idle-check" /usr/local/bin/idle-check
      sudo chmod +x /usr/local/bin/idle-check
      sudo cp "$DEVBOX_DIR/idle/devbox-idle.service" /etc/systemd/system/devbox-idle.service
      sudo cp "$DEVBOX_DIR/idle/devbox-idle.timer"   /etc/systemd/system/devbox-idle.timer
      sudo systemctl daemon-reload
      sudo systemctl enable --now devbox-idle.timer \
        && log_ok "devbox-idle timer enabled" \
        || { log_warn "devbox-idle timer failed"; _track_failed "idle timer"; }
    fi
  else
    if systemctl is-enabled devbox-idle.timer &>/dev/null; then
      log_info "Removing idle timer (disabled in profile)..."
      sudo systemctl stop devbox-idle.timer 2>/dev/null || true
      sudo systemctl disable devbox-idle.timer 2>/dev/null || true
      sudo rm -f /etc/systemd/system/devbox-idle.timer \
                 /etc/systemd/system/devbox-idle.service \
                 /usr/local/bin/idle-check
      sudo systemctl daemon-reload
      sudo systemctl reset-failed 2>/dev/null || true
      log_ok "idle timer removed"
    else
      log_info "idle timer: disabled in profile"
    fi
  fi
}

cmd_repos() {
  log_section "Workspace repos"

  local repos_raw
  repos_raw=$(curl -sf \
    --connect-timeout 5 \
    -H "Metadata-Flavor: Google" \
    "http://metadata.google.internal/computeMetadata/v1/instance/attributes/devbox-repos" \
    2>/dev/null || true)

  if [[ -z "$repos_raw" ]]; then
    log_info "No repos configured in profile"
    return
  fi

  if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
    log_warn "SSH agent not forwarded — private repo clones may fail (reconnect with ssh -A)"
  fi

  mkdir -p "$HOME/workspace"

  while IFS= read -r repo_url; do
    [[ -z "$repo_url" ]] && continue
    local repo_name repo_dest
    repo_name=$(basename "$repo_url" .git)
    repo_dest="$HOME/workspace/$repo_name"
    if [[ -d "$repo_dest" ]]; then
      log_info "$repo_name: already cloned"
    else
      log_info "$repo_name: cloning..."
      git clone "$repo_url" "$repo_dest" \
        && log_ok "$repo_name" \
        || { log_warn "$repo_name clone failed"; _track_failed "repo/$repo_name"; }
    fi
  done <<< "$repos_raw"
}

cmd_gui() {
  log_section "GUI install"

  # ---- Verify VirtIO GPU device is present --------------------------------
  if [[ ! -e /dev/dri/card0 ]]; then
    log_error "VirtIO GPU device not found (/dev/dri/card0 missing)"
    log_dim "Enable it in the profile (ENABLE_DISPLAY=true) and run:"
    log_dim "  devbox reset --profile \$DEVBOX_PROFILE"
    log_dim "or stop/start the VM to apply the Terraform change."
    _track_failed "virtio gpu"
    return 1
  fi
  log_ok "VirtIO GPU present (/dev/dri/card0)"

  # ---- Install apt packages -----------------------------------------------
  # Xorg (system service, no display manager) + XFCE4 (lightweight, headless-friendly).
  local gui_pkgs=(
    xorg
    xfce4
    xfce4-terminal
    dbus-x11
    firefox
  )

  log_info "Installing GUI packages via apt (this takes several minutes — output shown below)..."
  if DEBIAN_FRONTEND=noninteractive DEBIAN_PRIORITY=critical \
      sudo -E apt-get install -y "${gui_pkgs[@]}"; then
    log_ok "GUI packages installed"
  else
    log_warn "GUI package install failed"
    _track_failed "gui packages"
    return 1
  fi

  # ---- Install Google Chrome -----------------------------------------------
  if command -v google-chrome &>/dev/null; then
    log_info "Google Chrome: already installed"
  else
    log_info "Google Chrome: downloading..."
    local chrome_deb
    chrome_deb="$(mktemp --suffix=.deb)"
    if curl -fsSL -o "$chrome_deb" "https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb"; then
      DEBIAN_FRONTEND=noninteractive sudo apt-get install -y "$chrome_deb" \
        && log_ok "Google Chrome" \
        || { log_warn "Chrome install failed"; _track_failed "chrome"; }
    else
      log_warn "Chrome download failed"
      _track_failed "chrome download"
    fi
    rm -f "$chrome_deb"
  fi

  # ---- Install Ghostty terminal -------------------------------------------
  if command -v ghostty &>/dev/null; then
    log_info "Ghostty: already installed"
  else
    log_info "Ghostty: installing via ghostty-ubuntu..."
    if /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/mkasberg/ghostty-ubuntu/HEAD/install.sh)"; then
      log_ok "Ghostty"
    else
      log_warn "Ghostty install failed"
      _track_failed "ghostty"
    fi
  fi

  # ---- Install RustDesk from GitHub releases ------------------------------
  if command -v rustdesk &>/dev/null; then
    log_info "RustDesk: already installed"
  else
    log_info "RustDesk: fetching latest release info..."
    local rd_version rd_url rd_deb
    rd_version=$(curl -fsSL https://api.github.com/repos/rustdesk/rustdesk/releases/latest \
      | python3 -c "import json,sys; print(json.load(sys.stdin)['tag_name'])" 2>/dev/null) \
      || { log_warn "RustDesk: failed to fetch release info"; _track_failed "rustdesk install"; return 1; }
    rd_url="https://github.com/rustdesk/rustdesk/releases/download/${rd_version}/rustdesk-${rd_version}-x86_64-sciter.deb"
    rd_deb="$(mktemp --suffix=.deb)"
    log_info "RustDesk: downloading ${rd_version}..."
    if curl -fsSL -o "$rd_deb" "$rd_url"; then
      DEBIAN_FRONTEND=noninteractive sudo apt-get install -y "$rd_deb" >/dev/null 2>&1 \
        && log_ok "RustDesk ${rd_version}" \
        || { log_warn "RustDesk .deb install failed"; _track_failed "rustdesk install"; }
    else
      log_warn "RustDesk: download failed (${rd_url})"
      _track_failed "rustdesk download"
    fi
    rm -f "$rd_deb"
  fi

  # ---- Write systemd service units ----------------------------------------
  sudo tee /etc/systemd/system/xorg-display.service > /dev/null <<'UNIT'
[Unit]
Description=Xorg server on display :0
After=systemd-udev-settle.service
Wants=systemd-udev-settle.service

[Service]
ExecStart=/usr/bin/Xorg :0 -nolisten tcp vt1
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
UNIT

  sudo tee /etc/systemd/system/xfce4-session.service > /dev/null <<UNIT
[Unit]
Description=XFCE4 desktop session on display :0
After=xorg-display.service
Requires=xorg-display.service

[Service]
User=${USER}
Environment=DISPLAY=:0
Environment=HOME=${HOME}
ExecStartPre=/bin/sleep 2
ExecStart=/usr/bin/dbus-launch --exit-with-session /usr/bin/xfce4-session
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
UNIT

  sudo tee /etc/systemd/system/rustdesk.service > /dev/null <<UNIT
[Unit]
Description=RustDesk server daemon (direct IP mode)
After=xfce4-session.service
Requires=xorg-display.service

[Service]
User=${USER}
Environment=DISPLAY=:0
Environment=HOME=${HOME}
ExecStartPre=/bin/sleep 3
ExecStart=/usr/bin/rustdesk --server
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
UNIT

  sudo systemctl daemon-reload
  sudo systemctl enable xorg-display.service xfce4-session.service rustdesk.service
  log_ok "systemd services written and enabled"

  # ---- Configure RustDesk via CLI (requires root) --------------------------
  log_info "Configuring RustDesk options..."
  sudo rustdesk --option direct-server Y || true
  sudo rustdesk --option direct-access-port 21118 || true
  sudo rustdesk --option verification-method use-permanent-password || true
  sudo rustdesk --option approve-mode password || true
  sudo rustdesk --option whitelist 100.64.0.0/10 || true

  # Generate a password once; store the plaintext so we can display it later.
  local rd_password_file="${HOME}/.config/rustdesk/.gui_password"
  local rd_password
  if [[ -f "$rd_password_file" ]] && [[ -s "$rd_password_file" ]]; then
    rd_password=$(cat "$rd_password_file")
    log_info "RustDesk: reusing existing password"
  else
    rd_password=$(head -c 128 /dev/urandom | tr -dc 'A-Za-z0-9' | head -c 16 || true)
    mkdir -p "$(dirname "$rd_password_file")"
    printf '%s' "$rd_password" > "$rd_password_file"
    chmod 600 "$rd_password_file"
    log_info "RustDesk: generated new password"
  fi

  local pw_result
  pw_result=$(sudo rustdesk --password "$rd_password" 2>&1) || true
  if [[ "$pw_result" == *"Done"* ]]; then
    log_ok "RustDesk password set"
  else
    log_warn "RustDesk password may not have been set: $pw_result"
    _track_failed "rustdesk password"
  fi

  log_ok "GUI install complete — run 'rigging gui start' to start the session"
}

cmd_gui_start() {
  log_section "GUI start"

  # ---- Start all three services -------------------------------------------
  sudo systemctl restart xorg-display.service \
    && log_ok "Xorg started" \
    || { log_warn "Xorg failed to start — check: journalctl -u xorg-display"; _track_failed "xorg"; return 1; }

  local xorg_ready=false
  for i in {1..15}; do
    if DISPLAY=:0 xdpyinfo &>/dev/null 2>&1; then
      xorg_ready=true
      break
    fi
    sleep 1
  done
  if [[ "$xorg_ready" != true ]]; then
    log_warn "Xorg started but display :0 not reachable after 15s"
    log_dim "Check: journalctl -u xorg-display"
    _track_failed "xorg display"
    return 1
  fi
  log_ok "Xorg display :0 reachable"

  sudo systemctl restart xfce4-session.service \
    && log_ok "XFCE4 session started" \
    || { log_warn "XFCE4 failed — check: journalctl -u xfce4-session"; _track_failed "xfce4"; }

  sudo systemctl restart rustdesk.service \
    && log_ok "RustDesk daemon started" \
    || { log_warn "RustDesk failed — check: journalctl -u rustdesk"; _track_failed "rustdesk daemon"; }

  # ---- Print connection info -----------------------------------------------
  local ts_ip rd_password_file rd_password
  ts_ip=$(tailscale ip -4 2>/dev/null || true)
  rd_password_file="${HOME}/.config/rustdesk/.gui_password"
  rd_password=$(cat "$rd_password_file" 2>/dev/null || echo "(not set — run: rigging gui)")

  echo
  log_ok "GUI session ready"
  echo
  log_dim "  ┌─ Connection details ──────────────────────────────────────┐"
  if [[ -n "$ts_ip" ]]; then
    log_dim "  │  Tailscale IP : ${ts_ip}"
  else
    log_dim "  │  Tailscale IP : (not connected — run: sudo tailscale up)"
  fi
  log_dim "  │  Port         : 21118 (direct IP, no relay)"
  log_dim "  │  Password     : ${rd_password}"
  log_dim "  │"
  log_dim "  │  On your Mac:"
  log_dim "  │    1. Open RustDesk (brew install --cask rustdesk)"
  log_dim "  │    2. Enter the Tailscale IP in the address bar"
  log_dim "  │    3. Click Connect — enter the password above"
  log_dim "  │    4. Check 'Remember password' so you only type it once"
  log_dim "  └───────────────────────────────────────────────────────────┘"
  echo
  log_dim "  Password is also stored at: $rd_password_file"
  log_dim "  To stop the GUI:  rigging gui stop"
  log_dim "  To check status:  rigging check"
  echo
}

cmd_gui_stop() {
  log_section "GUI stop"

  log_info "Stopping RustDesk daemon..."
  sudo systemctl stop rustdesk 2>/dev/null \
    && log_ok "RustDesk daemon stopped" \
    || log_info "RustDesk daemon: not running"

  log_info "Stopping XFCE4 session..."
  sudo systemctl stop xfce4-session 2>/dev/null \
    && log_ok "XFCE4 session stopped" \
    || log_info "XFCE4 session: not running"

  log_info "Stopping Xorg..."
  sudo systemctl stop xorg-display.service 2>/dev/null \
    && log_ok "Xorg stopped" \
    || log_info "Xorg: not running"
}

cmd_check() {
  log_banner "rigging check"

  local missing=()

  _chk() {
    local label="$1" result="$2"
    if [[ "$result" == "ok" ]]; then
      log_ok "$label"
    else
      log_error "$label"
      missing+=("$label")
    fi
  }

  # Augment PATH so language checks find binaries installed outside Homebrew
  # (cargo, nvm-managed node, go workspace). This matters when rigging check
  # is invoked as a bash subprocess from welcome (which doesn't source .zshrc).
  [[ -f "${BREW_PREFIX}/bin/brew" ]] && eval "$("${BREW_PREFIX}/bin/brew" shellenv)" 2>/dev/null || true
  export PATH="${HOME}/.cargo/bin:${PATH}"
  export PATH="${BREW_PREFIX}/opt/rustup/bin:${PATH}"
  export NVM_DIR="${HOME}/.nvm"
  # shellcheck source=/dev/null
  [[ -s "${BREW_PREFIX}/opt/nvm/nvm.sh" ]] && source "${BREW_PREFIX}/opt/nvm/nvm.sh" 2>/dev/null || true
  export PATH="${HOME}/go/bin:${PATH}"

  log_section "Homebrew"
  [[ -x "${BREW_PREFIX}/bin/brew" ]] \
    && _chk "Homebrew" ok || _chk "Homebrew" fail

  log_section "Dotfiles"
  [[ -f "$HOME/.hushlogin" ]] \
    && _chk ".hushlogin" ok || _chk ".hushlogin" fail
  local stow="${BREW_PREFIX}/bin/stow"
  for pkg in aliases atuin claude git ghostty nvim opencode starship tmux zsh; do
    "$stow" -d "$CONFIG_DIR" -n "$pkg" -t "$HOME" &>/dev/null \
      && _chk "stow $pkg" ok || _chk "stow $pkg (already linked)" ok
  done

  log_section "Languages"
  command -v rustc   &>/dev/null && _chk "rust"   ok || _chk "rust"   fail
  command -v node    &>/dev/null && _chk "node"   ok || _chk "node"   fail
  command -v go      &>/dev/null && _chk "go"     ok || _chk "go"     fail
  command -v python3 &>/dev/null && _chk "python" ok || _chk "python" fail

  log_section "Tools"
  [[ -d "$HOME/.tmux/plugins/tpm" ]]  && _chk "tpm"      ok || _chk "tpm"      fail
  command -v claude   &>/dev/null      && _chk "claude"   ok || _chk "claude"   fail
  command -v opencode &>/dev/null      && _chk "opencode" ok || _chk "opencode" fail
  command -v gcloud   &>/dev/null      && _chk "gcloud"   ok || _chk "gcloud"   fail

  log_section "Docker"
  command -v docker &>/dev/null                          && _chk "docker installed" ok || _chk "docker installed" fail
  systemctl is-active docker &>/dev/null                 && _chk "docker running"   ok || _chk "docker running"   fail
  getent group docker | grep -qw "$USER" 2>/dev/null     && _chk "docker group"     ok || _chk "docker group"     fail

  log_section "Tailscale"
  command -v tailscale &>/dev/null \
    && _chk "tailscale installed" ok || _chk "tailscale installed" fail
  systemctl is-active tailscaled &>/dev/null \
    && _chk "tailscaled running" ok || _chk "tailscaled running" fail
  tailscale status --json 2>/dev/null | grep -q '"BackendState": "Running"' \
    && _chk "tailscale authenticated" ok || _chk "tailscale authenticated" fail

  log_section "Idle timer"
  if _idle_timer_enabled; then
    systemctl is-enabled devbox-idle.timer &>/dev/null \
      && _chk "devbox-idle timer" ok || _chk "devbox-idle timer" fail
  else
    log_info "idle timer disabled in profile"
  fi

  log_section "GUI (optional)"
  if [[ -e /dev/dri/card0 ]]; then
    _chk "VirtIO GPU (/dev/dri/card0)" ok
    command -v rustdesk &>/dev/null \
      && _chk "rustdesk installed" ok || _chk "rustdesk installed" fail
    systemctl is-active xorg-display.service &>/dev/null \
      && _chk "Xorg running" ok || log_info "Xorg: not running (run: rigging gui)"
    systemctl is-active xfce4-session &>/dev/null \
      && _chk "XFCE4 session running" ok || log_info "XFCE4: not running (run: rigging gui)"
    systemctl is-active rustdesk &>/dev/null \
      && _chk "rustdesk daemon" ok || log_info "rustdesk daemon: not running (run: rigging gui)"
    DISPLAY=:0 xdpyinfo &>/dev/null \
      && _chk "X display :0 reachable" ok || log_info "X display :0: not reachable (run: rigging gui)"

    local ts_ip rd_password
    ts_ip=$(tailscale ip -4 2>/dev/null || true)
    local rd_pw_file="$HOME/.config/rustdesk/.gui_password"
    rd_password=$(cat "$rd_pw_file" 2>/dev/null || echo "(not set — run: rigging gui)")
    echo
    log_dim "  ┌─ RustDesk connection ─────────────────────────────────────┐"
    if [[ -n "$ts_ip" ]]; then
      log_dim "  │  Tailscale IP : ${ts_ip}"
    else
      log_dim "  │  Tailscale IP : (not connected — run: sudo tailscale up)"
    fi
    log_dim "  │  Port         : 21118"
    log_dim "  │  Password     : ${rd_password}"
    log_dim "  └───────────────────────────────────────────────────────────┘"
    echo
  else
    log_info "VirtIO GPU not present — GUI not enabled (ENABLE_DISPLAY=false in profile)"
  fi

  log_section "Secrets"
  [[ -s "$HOME/.config/secrets.env" ]] \
    && _chk "~/.config/secrets.env" ok || _chk "~/.config/secrets.env" fail

  echo
  if [[ ${#missing[@]} -eq 0 ]]; then
    log_ok "All components installed"
  else
    log_error "${#missing[@]} component(s) missing — run: rigging"
    exit 1
  fi
}

cmd_all() {
  log_banner "rigging"
  cmd_install
  cmd_link
  cmd_langs
  cmd_tools
  cmd_docker
  cmd_tailscale
  cmd_idle
  cmd_repos
  cmd_gui
  cmd_gui_start
  _secrets_check
  _summary
}

cmd_help() {
  cat <<EOF

  rigging — provision a fresh devbox VM

  Usage: rigging [command]

  Commands:
    all          Run everything  (default)
    install      Homebrew + brew bundle
    link         Stow dotfiles + .hushlogin
    langs        Language toolchains via pkgs/lang/*
    tools        Claude code, opencode, TPM, atuin, tldr
    docker       Docker Engine + daemon + group membership
    tailscale    Install Tailscale daemon + authenticate
    idle         Systemd idle timer
    repos        Clone workspace repos from GCE metadata
    gui          Install GUI stack (XFCE4, RustDesk, Chrome, Ghostty)
    gui start    Start the GUI session (Xorg + XFCE4 + RustDesk)
    gui stop     Stop the GUI session
    check        Print ✓/✗ status without modifying anything
    help         Show this message

EOF
}

_secrets_check() {
  log_section "Secrets"
  if [[ -s "$HOME/.config/secrets.env" ]]; then
    local vars
    mapfile -t vars < <(grep -oP '^(export\s+)?\K[A-Z_][A-Z0-9_]+(?==)' \
      "$HOME/.config/secrets.env" 2>/dev/null || true)
    log_ok "~/.config/secrets.env (${#vars[@]} vars)"
    for v in "${vars[@]}"; do log_dim "  · $v"; done
  else
    log_warn "~/.config/secrets.env not found — run bin/start to copy your profile .env file"
  fi
}

_summary() {
  echo
  if [[ ${#FAILED[@]} -eq 0 ]]; then
    log_ok "Rigging complete — log out and back in for shell changes to take effect"
  else
    log_warn "Rigging complete with ${#FAILED[@]} failure(s):"
    for f in "${FAILED[@]}"; do log_dim "  · $f"; done
    log_dim "Re-run rigging to retry."
  fi
  echo
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
main() {
  local cmd="${1:-all}"
  shift || true

  # Subcommands that need the profile resolved first
  case "$cmd" in
    all|install|link|langs|tools|docker|tailscale|idle|repos|gui)
      _resolve_profile
      ;;
  esac

  case "$cmd" in
    all)            cmd_all ;;
    install)   log_banner "rigging install";    cmd_install;   _summary ;;
    link)      log_banner "rigging link";       cmd_link;      _summary ;;
    langs)     log_banner "rigging langs";      cmd_langs;     _summary ;;
    tools)     log_banner "rigging tools";      cmd_tools;     _summary ;;
    docker)    log_banner "rigging docker";     cmd_docker;    _summary ;;
    tailscale) log_banner "rigging tailscale";  cmd_tailscale; _summary ;;
    idle)      log_banner "rigging idle";       cmd_idle;      _summary ;;
    repos)     log_banner "rigging repos";      cmd_repos;     _summary ;;
    gui)
      local subcmd="${1:-}"
      case "$subcmd" in
        start) log_banner "rigging gui start"; cmd_gui_start; _summary ;;
        stop)  log_banner "rigging gui stop";  cmd_gui_stop;  _summary ;;
        "")    log_banner "rigging gui";       cmd_gui;       _summary ;;
        *)
          log_error "Unknown gui subcommand: $subcmd"
          log_dim "Usage: rigging gui [start|stop]"
          exit 1
          ;;
      esac
      ;;
    check)     _resolve_profile; cmd_check ;;
    help|--help|-h) cmd_help ;;
    *)
      log_error "Unknown command: $cmd"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
