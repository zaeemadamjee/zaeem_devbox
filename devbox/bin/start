#!/usr/bin/env bash
# start — Start a devbox VM and SSH into it.
#
# Usage: ./bin/start --profile <name>
#
# Adds a "devbox-<profile>" entry to ~/.ssh/config on first run.
# Updates HostName with the current ephemeral IP on subsequent runs.

set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$BIN_DIR/../lib/profile"
source "$BIN_DIR/../lib/ssh.sh"

PROFILE=$(parse_profile_flag "$@")
load_profile "$PROFILE"
check_gcp_project
check_gcloud_auth
resolve_instance_zone

SSH_KEY="$HOME/.ssh/zaeem"
SSH_USER="zaeem"
SSH_CONFIG="$HOME/.ssh/config"
SSH_HOST="devbox-${PROFILE_NAME}"

# ---------------------------------------------------------------------------
# SSH agent check
# ---------------------------------------------------------------------------
if ! ssh-add -l &>/dev/null; then
  log_warn "SSH agent has no keys loaded"
  log_dim "If this is a fresh VM, the repo clone will fail without agent forwarding."
  log_dim "Fix: ssh-add ~/.ssh/zaeem"
  echo
fi

# ---------------------------------------------------------------------------
# VM: start + wait for SSH
# ---------------------------------------------------------------------------
log_section "VM ($GCP_INSTANCE_NAME)"

log_info "Starting $GCP_INSTANCE_NAME..."
_gcloud_tmp=$(mktemp)
if ! gcloud compute instances start "$GCP_INSTANCE_NAME" \
       --zone="$GCP_ZONE" --project="$GCP_PROJECT" --quiet \
       >"$_gcloud_tmp" 2>&1; then
  while IFS= read -r _line; do log_dim "  $_line"; done < "$_gcloud_tmp"
  rm -f "$_gcloud_tmp"
  exit 1
fi
rm -f "$_gcloud_tmp"
log_ok "Instance started"

IP_FILE=$(mktemp)
trap 'rm -f "$IP_FILE"' EXIT

log_info "Waiting for SSH (up to 2.5 min)..."
if ! ssh_wait_ready "$GCP_INSTANCE_NAME" "$GCP_ZONE" "$GCP_PROJECT" "$SSH_USER" "$IP_FILE"; then
  log_error "Could not reach VM over SSH after polling"
  _diagnose_ssh_failure "$GCP_INSTANCE_NAME" "$GCP_ZONE" "$GCP_PROJECT" "$SSH_USER"
  exit 1
fi
IP=$(cat "$IP_FILE")
log_ok "VM is up at $IP"

# ---------------------------------------------------------------------------
# Open ControlMaster — all setup steps reuse this single connection
# ---------------------------------------------------------------------------
log_info "Opening SSH master connection..."
if ! ssh_retry 3 5 ssh_master_open "$SSH_USER" "$IP"; then
  log_error "Could not open SSH master connection"
  exit 1
fi
log_ok "Master connection established"

# Ensure master is closed on exit regardless of what follows
trap 'ssh_master_close "$SSH_USER" "$IP" 2>/dev/null; rm -f "$IP_FILE"' EXIT

# ---------------------------------------------------------------------------
# Wait for startup script via master
# ---------------------------------------------------------------------------
log_info "Waiting for startup script to complete (up to 2.5 min)..."
if ! ssh_wait_startup "$SSH_USER" "$IP"; then
  log_warn "Startup script did not complete within expected time — connecting anyway"
else
  log_ok "Startup script complete"
fi

ssh-keygen -R "$IP" &>/dev/null || true

# ---------------------------------------------------------------------------
# Setup: secrets, terminfo
# ---------------------------------------------------------------------------
log_section "Setup"

LOCAL_SECRETS="$REPO_ROOT/devbox/profiles/${PROFILE_NAME}.env"
if [[ -f "$LOCAL_SECRETS" ]]; then
  log_info "Copying secrets (${PROFILE_NAME}.env)..."
  if ssh_master_pipe "$SSH_USER" "$IP" \
       'set -e
        mkdir -p ~/.config && chmod 700 ~/.config
        cat > ~/.config/secrets.env
        chmod 600 ~/.config/secrets.env' \
       < "$LOCAL_SECRETS"; then
    log_ok "Secrets copied to ~/.config/secrets.env"
  else
    log_warn "Failed to copy secrets — you can retry by re-running bin/start"
  fi
else
  log_warn "No secrets file at ${LOCAL_SECRETS} — skipping"
fi

log_info "Installing Ghostty terminfo..."
if infocmp -x | ssh_master_pipe "$SSH_USER" "$IP" -- tic -x - 2>/dev/null; then
  log_ok "Ghostty terminfo installed"
else
  log_warn "Could not install Ghostty terminfo (non-fatal, will retry on next start)"
fi

# ---------------------------------------------------------------------------
# SSH config: add or update devbox-<profile> entry
# ---------------------------------------------------------------------------
log_section "SSH config"

touch "$SSH_CONFIG"
chmod 600 "$SSH_CONFIG"

if grep -q "^Host ${SSH_HOST}$" "$SSH_CONFIG" 2>/dev/null; then
  # Update managed keys within the existing stanza using POSIX awk.
  # $2 is the key name (first non-whitespace token after leading indent).
  # $1 preserves the leading whitespace via the OFS trick.
  # Replaces the value of any managed key found in the stanza; leaves all
  # other lines (including keys we don't manage) untouched.
  awk -v host="$SSH_HOST" \
      -v HostName="$IP" \
      -v IdentityFile="$SSH_KEY" \
      -v ConnectTimeout="10" \
      -v ServerAliveInterval="5" \
      -v ServerAliveCountMax="3" \
    '
    BEGIN { in_stanza=0 }
    /^Host / {
      in_stanza = ($0 == "Host " host)
    }
    in_stanza && /^[[:space:]]+(HostName|IdentityFile|ConnectTimeout|ServerAliveInterval|ServerAliveCountMax)[[:space:]]/ {
      key = $1
      indent = substr($0, 1, index($0, key) - 1)
      if (key == "HostName")             { print indent key " " HostName;             next }
      if (key == "IdentityFile")         { print indent key " " IdentityFile;         next }
      if (key == "ConnectTimeout")       { print indent key " " ConnectTimeout;       next }
      if (key == "ServerAliveInterval")  { print indent key " " ServerAliveInterval;  next }
      if (key == "ServerAliveCountMax")  { print indent key " " ServerAliveCountMax;  next }
    }
    { print }
    ' "$SSH_CONFIG" > "${SSH_CONFIG}.tmp" && mv "${SSH_CONFIG}.tmp" "$SSH_CONFIG"
  log_ok "Updated $SSH_HOST → $IP"
else
  cat >> "$SSH_CONFIG" <<EOF

Host ${SSH_HOST}
  HostName $IP
  User $SSH_USER
  IdentityFile $SSH_KEY
  StrictHostKeyChecking no
  ForwardAgent yes
  ConnectTimeout 10
  ServerAliveInterval 5
  ServerAliveCountMax 3
EOF
  log_ok "Added $SSH_HOST to SSH config"
fi

# ---------------------------------------------------------------------------
# Close master and open interactive session
# ---------------------------------------------------------------------------
ssh_master_close "$SSH_USER" "$IP"
# Reset trap now that master is closed cleanly
trap 'rm -f "$IP_FILE"' EXIT

echo
log_info "Connecting to $SSH_HOST..."
echo

ssh_retry 3 5 ssh -A -o LogLevel=ERROR "$SSH_HOST"
