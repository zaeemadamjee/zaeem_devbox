#!/usr/bin/env bash
# stop — Manually stop a devbox VM.
#
# Usage: ./bin/stop --profile <name>
#
# The VM also auto-stops after 20 minutes of idle (via systemd timer, if enabled).
# Use this script to stop it immediately.

set -euo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$BIN_DIR/../lib/profile"

PROFILE=$(parse_profile_flag "$@")
load_profile "$PROFILE"
check_gcp_project
check_gcloud_auth
resolve_instance_zone

_gcloud_tmp=$(mktemp)
_stop_max=120

# Run gcloud stop in a background subshell that writes its exit code to a file.
# This avoids bash job-control "Done" notifications on completion.
_gcloud_rc_file="${_gcloud_tmp}.rc"
( gcloud compute instances stop "$GCP_INSTANCE_NAME" --zone="$GCP_ZONE" --project="$GCP_PROJECT" --quiet >"$_gcloud_tmp" 2>&1; echo $? >"$_gcloud_rc_file" ) &
_gcloud_pid=$!
disown "$_gcloud_pid" 2>/dev/null || true

_elapsed=0
while true; do
  kill -0 "$_gcloud_pid" 2>/dev/null || break
  log_progress_bar "$_elapsed" "$_stop_max" "Stopping VM"
  sleep 1
  _elapsed=$(( _elapsed + 1 ))
done

log_progress_bar_clear

# Read exit code written by the subshell.
_stop_rc=0
[[ -f "$_gcloud_rc_file" ]] && _stop_rc=$(cat "$_gcloud_rc_file")
rm -f "$_gcloud_rc_file"
if [[ "$_stop_rc" -ne 0 ]]; then
  while IFS= read -r _line; do log_dim "  $_line"; done < "$_gcloud_tmp"
  rm -f "$_gcloud_tmp"
  exit 1
fi
rm -f "$_gcloud_tmp"

log_ok "$GCP_INSTANCE_NAME stopped"
log_dim "disk persists — no compute charges until next start"
